rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isRole(role) {
      // Uses Custom Claims (JWT token) instead of reading the user document.
      // Custom Claims are set by the Cloud Function 'syncRoleToClaims'.
      return isAuthenticated() && request.auth.token.role == role;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSetupOpen() {
      // Allow setup if the specific setup document doesn't exist
      return !exists(/databases/$(database)/documents/_setup/config);
    }

    // Helper to ensure user only updates their own non-sensitive fields
    function isOwnerSafeUpdate(userId) {
      return isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['name', 'email', 'phone', 'avatar', 'birthDate', 'mustChangePassword']);
    }

    // Helper to validate message updates by sender
    function isMessageSenderUpdate() {
      return resource.data.senderId == request.auth.uid &&
             request.resource.data.senderId == request.auth.uid && // No transfer
             request.resource.data.receiverId == resource.data.receiverId && // No redirect
             request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['subject', 'content', 'attachments', 'archived', 'updatedAt']);
    }

    // Helper to validate message updates by receiver (read status)
    function isMessageReceiverUpdate() {
      return resource.data.receiverId == request.auth.uid &&
             request.resource.data.senderId == resource.data.senderId && // No spoofing
             request.resource.data.receiverId == request.auth.uid && // No redirect
             request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['read', 'archived', 'updatedAt']);
    }

    function isTeacher() { return isRole('teacher'); }
    function isDirector() { return isRole('director'); }
    function isParent() { return isRole('parent'); }
    function isStudent() { return isRole('student'); }
    function isSuperAdmin() { return isRole('superadmin'); }

    // New Helper: Check if score is valid (0 <= score <= maxScore)
    function isValidGrade() {
      let score = request.resource.data.score;
      let max = request.resource.data.maxScore;
      return score >= 0 && score <= max;
    }

    // New Helper: Check if user can read another user's profile
    // Allow reading if:
    // 1. It's my own profile
    // 2. I'm a teacher/director/admin (staff)
    // 3. We are in the same class (for students)
    function canReadUserProfile(targetUserData) {
       return isOwner(targetUserData.id) ||
              isTeacher() ||
              isDirector() ||
              isSuperAdmin() ||
              (isStudent() && getUserData().classId == targetUserData.classId);
    }

    // Helper: Check if teacher is assigned to the class
    // SECURITY: Queries the 'classes' collection directly by teacherId,
    // because user.classIds on the Teacher doc may NOT be synced.
    // Do NOT revert to checking getUserData().classIds — it's unreliable.
    function isTeacherForClass(classId) {
      return isTeacher() && 
        get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
    }

    // --- Collection Rules ---

    // Users:
    // - Read: Restricted to own profile, staff, or classmates.
    // - Write: Users can update their own phone/avatar/name (whitelisted fields). Directors/Admins can manage all.
    match /users/{userId} {
      // Improved Read Rule:
      allow read: if isAuthenticated() && (
        isOwner(userId) ||
        isTeacher() ||
        isDirector() ||
        isSuperAdmin() ||
        (isStudent() && getUserData().classId == resource.data.classId)
      );

      allow delete: if isDirector() || isSuperAdmin();

      // 🛡️ SECURITY: Prevent Privilege Escalation
      // Allow superadmin creation ONLY if setup is open.
      allow create: if isDirector() || isSuperAdmin() || (isSetupOpen() && request.resource.data.role == 'superadmin');
      // Only allow users to update their own profile fields.
      // Critical: Prevent updating 'role', 'classId', 'childrenIds', etc.
      allow update: if isDirector() || isSuperAdmin() || isOwnerSafeUpdate(userId);
    }

    // Setup Document Status
    // Unrestricted read, but can only be created once when setting up the system
    match /_setup/{docId} {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/_setup/config);
    }

    // Grades (Legacy Collection Group):
    // - Read: User sees their own. Parents see their children's. Teachers see grades they gave or for their classes.
    // - Write: Teachers can add/edit grades.
    match /grades/{gradeId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid || 
        (isParent() && resource.data.studentId in getUserData().childrenIds) ||
        // SECURITY: Teachers only see grades for their own classes
        (isTeacher() && isTeacherForClass(resource.data.classId)) || 
        isDirector() ||
        isSuperAdmin()
      );
      // Improved Write Rule: Validate Score Range and Class Access
      // SECURITY FIX: Use isTeacherForClass() instead of classIds (unreliable)
      allow write: if (isDirector() || isSuperAdmin() || (isTeacher() && isTeacherForClass(request.resource.data.classId))) && isValidGrade();
    }

    // CourseGrades (New Collection):
    match /courseGrades/{gradeId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        (isParent() && resource.data.studentId in getUserData().childrenIds) ||
        // SECURITY: Teachers only see grades for their own classes
        (isTeacher() && isTeacherForClass(resource.data.classId)) ||
        isDirector() ||
        isSuperAdmin()
      );
      // Improved Write Rule: Validate Score Range and Class Access
      // SECURITY FIX: Use isTeacherForClass() instead of classIds (unreliable)
      allow write: if (isDirector() || isSuperAdmin() || (isTeacher() && isTeacherForClass(request.resource.data.classId))) && isValidGrade();
    }

    // Attendance:
    // - Similar to Grades.
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid || 
        (isParent() && resource.data.studentId in getUserData().childrenIds) ||
        isTeacher() || 
        isDirector()
      );
      allow write: if isTeacher() || isDirector(); // Teachers modify attendance
    }

    // Homework:
    // - Read: Students in key class, Parents of students in key class, Teachers.
    // - Write: Teachers (restricted to their classes), Directors, Admins.
    match /homeworks/{homeworkId} {
      allow read: if isAuthenticated() && (
        isTeacher() ||
        isDirector() ||
        isSuperAdmin() ||
        (isStudent() && getUserData().classId == resource.data.classId) ||
        (isParent() && resource.data.classId in getUserData().relatedClassIds)
      );

      // 🛡️ SECURITY: Prevent IDOR/Unauthorized Writes
      // Teachers can only create/update homework for classes they are assigned to.

      allow create: if isDirector() || isSuperAdmin() || isTeacherForClass(request.resource.data.classId);

      allow update: if isDirector() || isSuperAdmin() || (
        isTeacherForClass(request.resource.data.classId) &&
        resource.data.classId == request.resource.data.classId
      );

      allow delete: if isDirector() || isSuperAdmin() || isTeacherForClass(resource.data.classId);
    }

    // Submissions (Subcollection)
    // 🛡️ SECURITY: Prevent Unauthorized Access to Submissions
    match /homeworks/{homeworkId}/submissions/{submissionId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        (isParent() && resource.data.studentId in getUserData().childrenIds) ||
        isTeacher() || isDirector() || isSuperAdmin()
      );

      allow create: if isAuthenticated() && (
        (
          isStudent() &&
          request.resource.data.studentId == request.auth.uid &&
          // Verify student belongs to the homework's class
          getUserData().classId == get(/databases/$(database)/documents/homeworks/$(homeworkId)).data.classId
        ) ||
        (isParent() && request.resource.data.studentId in getUserData().childrenIds)
      );

      allow update: if isAuthenticated() && (
        (
          (
            (isStudent() && resource.data.studentId == request.auth.uid) ||
            (isParent() && resource.data.studentId in getUserData().childrenIds)
          ) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['content', 'files', 'submittedAt'])
        ) ||
        (isTeacher() || isDirector() || isSuperAdmin())
      );
    }

    // Courses/Schedule (subcollection under classes):
    // SECURITY: Read access is scoped per role.
    // - Students/Parents: only courses in their class(es)
    // - Teachers: all courses (filtered client-side by teacherId)
    // - Directors/Admins: all courses
    // Write: Only directors/superadmins can manage the schedule.
    // Root-level courses collection (used by collectionGroup queries)
    // SECURITY: Restricted to staff roles only — students/parents should
    // access courses via the scoped subcollection classes/{classId}/courses.
    match /courses/{courseId} {
      allow read: if isAuthenticated() && (
        isTeacher() || isDirector() || isSuperAdmin()
      );
      allow write: if isDirector() || isSuperAdmin();
    }

    // Classes:
    // SECURITY: Read access scoped per role.
    // - Students see only their class, parents see children's classes
    // - Teachers see classes they teach
    // - Directors/Admins see all
    // Write: Only directors/superadmins.
    match /classes/{classId} {
      allow read: if isAuthenticated() && (
        isDirector() || isSuperAdmin() ||
        (isTeacher() && isTeacherForClass(classId)) ||
        (isStudent() && getUserData().classId == classId) ||
        (isParent() && classId in getUserData().relatedClassIds)
      );
      allow write: if isDirector() || isSuperAdmin();

      // Courses subcollection under classes
      match /courses/{courseId} {
        allow read: if isAuthenticated() && (
          isDirector() || isSuperAdmin() ||
          (isTeacher() && ('teacherId' in resource.data) && resource.data.teacherId == request.auth.uid) ||
          (isTeacher() && isTeacherForClass(classId)) ||
          (isStudent() && getUserData().classId == classId) ||
          (isParent() && classId in getUserData().relatedClassIds)
        );
        allow write: if isDirector() || isSuperAdmin() || isTeacherForClass(classId);
      }
    }

    // Messages:
    // - Read: Sender or Receiver.
    // - Write: Sender must be auth user and match senderId.
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        resource.data.receiverId == 'all' // Public announcements
      );
      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid &&
        (
          request.resource.data.receiverId != 'all' ||
          isDirector() ||
          isSuperAdmin()
        );

      // 🛡️ SECURITY: Prevent Impersonation & Content Tampering
      // - Sender can update content (but not senderId/receiverId)
      // - Receiver can mark as read/archived (but not change content)
      allow update: if isAuthenticated() && (isMessageSenderUpdate() || isMessageReceiverUpdate());

      // Only sender can delete (hard delete)
      allow delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }
    
    // Events:
    // SECURITY: Restricted strictly by classId to prevent cross-class leakage
    match /events/{eventId} {
      allow read: if isAuthenticated() && (
        isDirector() || isSuperAdmin() ||
        !('classId' in resource.data) || resource.data.classId == null ||
        (isTeacher() && isTeacherForClass(resource.data.classId)) ||
        (isStudent() && getUserData().classId == resource.data.classId) ||
        (isParent() && resource.data.classId in getUserData().relatedClassIds)
      );
      
      // SECURITY: Teachers can only create events for their own classes
      allow create: if isDirector() || isSuperAdmin() || (
        isTeacher() && isTeacherForClass(request.resource.data.classId)
      );
      
      // SECURITY: Teachers can only update/delete events for their own classes
      allow update: if isDirector() || isSuperAdmin() || (
        isTeacher() && isTeacherForClass(resource.data.classId)
      );
      
      allow delete: if isDirector() || isSuperAdmin() || (
        isTeacher() && isTeacherForClass(resource.data.classId)
      );
    }

    // Academic Periods & Categories (Bulletin System)
    match /academicPeriods/{periodId} {
      allow read: if isAuthenticated();
      allow write: if isDirector() || isSuperAdmin();
    }
    match /gradeCategories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isDirector() || isSuperAdmin();
    }

    // Announcements:
    // - Read: All authenticated users (announcements are school-wide).
    // - Write: Directors and superadmins only.
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create: if isDirector() || isSuperAdmin();
      allow update: if isDirector() || isSuperAdmin();
      allow delete: if isDirector() || isSuperAdmin();
    }

    // Teacher Comments (Bulletin System):
    // - Read: The student, their parents, the author teacher, directors/admins.
    // - Write: Teachers (own comments), directors/admins.
    match /teacherComments/{commentId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        (isParent() && resource.data.studentId in getUserData().childrenIds) ||
        resource.data.teacherId == request.auth.uid ||
        isDirector() ||
        isSuperAdmin()
      );
      allow create: if isTeacher() || isDirector() || isSuperAdmin();
      allow update: if isAuthenticated() && (
        resource.data.teacherId == request.auth.uid ||
        isDirector() ||
        isSuperAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.teacherId == request.auth.uid ||
        isDirector() ||
        isSuperAdmin()
      );
    }
  }
}

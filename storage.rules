rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // SECURITY: Default deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Profile pictures: user uploads to profiles/{userId}/...
    // Read: All authenticated users (needed for displaying avatars across the UI).
    // Write: Only the user themselves, images only.
    match /profiles/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 25 * 1024 * 1024  // Max 25MB
        && request.resource.contentType.matches('image/.*');  // Images only
    }

    // Homework submissions: homework/{homeworkId}/{studentId}/...
    // Read/Delete: Student owner, director, superadmin.
    // Write: Only the student themselves with strict file type/size checks.
    match /homework/{homeworkId}/{studentId}/{fileName} {
      allow read: if request.auth != null
        && (
          request.auth.uid == studentId ||
          request.auth.token.role in ['director', 'superadmin']
        );
      allow write: if request.auth != null 
        && request.auth.uid == studentId
        && request.resource.size < 25 * 1024 * 1024  // Max 25MB
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType.matches('application/vnd\\..*')
          || request.resource.contentType.matches('application/.*zip.*')
          || request.resource.contentType == 'application/x-rar-compressed'
          || request.resource.contentType == 'text/plain'
        );
      allow delete: if request.auth != null
        && (
          request.auth.uid == studentId ||
          request.auth.token.role in ['director', 'superadmin']
        );
    }

    // Message attachments: messages/{senderId}/{fileName}
    // Read: Sender can read. Receiver can read if they have the signed URL OR
    //       if the file metadata contains their receiverId (which the sender should set on upload).
    // Write: Only the sender themselves.
    match /messages/{senderId}/{fileName} {
      allow read: if request.auth != null && (
        request.auth.uid == senderId || 
        (resource.metadata != null && resource.metadata.receiverId == request.auth.uid) ||
        (resource.metadata != null && resource.metadata.receiverId == 'all')
      );
      allow write: if request.auth != null
        && request.auth.uid == senderId
        && request.resource.size < 25 * 1024 * 1024;  // Max 25MB
    }

    // Event attachments: events/{eventId}/...
    // Read: All authenticated users (events are visible to all school members).
    // Write: Only teachers, directors, and superadmins can upload event files.
    // SECURITY: Uses Custom Claims to restrict by role.
    match /events/{eventId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.role in ['teacher', 'director', 'superadmin']
        && request.resource.size < 25 * 1024 * 1024  // Max 25MB
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf'
            || request.resource.contentType.matches('application/vnd\\..*')
            || request.resource.contentType.matches('application/.*zip.*')
            || request.resource.contentType == 'text/plain');
    }

    // General school documents
    // Read: All authenticated users (school-wide documents).
    // Write: Only directors and superadmins can upload official school documents.
    // SECURITY: Uses Custom Claims to restrict by role.
    match /documents/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.role in ['director', 'superadmin']
        && request.resource.size < 25 * 1024 * 1024  // Max 25MB
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf'
            || request.resource.contentType.matches('application/vnd\\..*')
            || request.resource.contentType.matches('application/.*zip.*')
            || request.resource.contentType == 'text/plain');
    }

    // User data folder (used for deleteUserData cleanup)
    // Read/Delete: user owner + director/superadmin for compliant data cleanup.
    // Write: only user owner.
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null
        && (
          request.auth.uid == userId ||
          request.auth.token.role in ['director', 'superadmin']
        );
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 25 * 1024 * 1024;  // Max 25MB
      allow delete: if request.auth != null
        && (
          request.auth.uid == userId ||
          request.auth.token.role in ['director', 'superadmin']
        );
    }
  }
}

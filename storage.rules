rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // SECURITY: Default deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Profile pictures: user uploads to profiles/{userId}/...
    // All authenticated users can read (for display in UI).
    match /profiles/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 25 * 1024 * 1024  // Max 25MB
        && request.resource.contentType.matches('image/.*');  // Images only
    }

    // Homework submissions: homework/{homeworkId}/{studentId}/...
    match /homework/{homeworkId}/{studentId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == studentId
        && request.resource.size < 25 * 1024 * 1024;  // Max 25MB
    }

    // Message attachments: messages/{senderId}/...
    match /messages/{senderId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == senderId
        && request.resource.size < 25 * 1024 * 1024;  // Max 25MB
    }

    // Event attachments: events/{eventId}/...
    // Teachers and directors can upload event attachments.
    match /events/{eventId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;  // Max 25MB
    }

    // General school documents (only directors/superadmins)
    match /documents/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;  // Max 25MB
    }

    // User data folder (used for deleteUserData cleanup)
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 25 * 1024 * 1024;  // Max 25MB
      allow delete: if request.auth != null;
    }
  }
}

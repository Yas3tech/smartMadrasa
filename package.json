{
  "name": "smartmadrassa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20 <23",
    "pnpm": ">=10"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": "^3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "rollup@<4.59.0": "^4.59.0",
      "flatted": ">=3.4.0"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest --run",
    "verify-rules": "node scripts/verify_rules_mock.js",
    "verify-rules:all": "node scripts/verify_rules_mock.js && node scripts/verify_grade_rules.js && node scripts/verify_homework_rules.js && node scripts/verify_message_rules.js && node scripts/verify_submission_rules.js",
    "audit:deps": "pnpm audit --audit-level high",
    "validate:env:prod": "node scripts/validate_env.js production",
    "ci:quality": "pnpm type-check && pnpm lint && pnpm test:run",
    "ci:security": "pnpm verify-rules:all && pnpm audit:deps",
    "predeploy:prod": "pnpm validate:env:prod && pnpm ci:quality && pnpm build"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "firebase": "^12.11.0",
    "i18next": "^25.8.19",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.554.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "^2.10.8",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "firebase-admin": "^13.7.0",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "terser": "^5.46.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}